---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { formatDate } from "../../utils";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog">
  <h1 class="mb-8 text-4xl font-bold">Blog</h1>
  <div class="flex flex-col space-y-3">
    {
      sortedPosts.map((post) => (
        <a
          href={`/blog/${post.slug}`}
          class="hover:text-blue-500 group flex items-baseline justify-between"
        >
          <span class="underline text-lg">{post.data.title}</span>
          <span class="text-sm text-gray-400 group-hover:text-blue-500">
            {formatDate(post.data.date)}
          </span>
        </a>
      ))
    }
  </div>
</Layout>
